// firestore.rules
//
// Deploy with: firebase deploy --only firestore:rules
//
// These rules enforce:
//  - Only authenticated users can read/write
//  - Users can only read/write their own profile
//  - Only conversation participants can read/write messages
//  - No one can edit or delete sent messages (append-only)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ───────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read profiles (needed for public key exchange)
      allow read: if request.auth != null;

      // Only the user themselves can write their profile
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;  // never delete accounts via client
    }

    // ── CONVERSATIONS ─────────────────────────────────────────
    match /conversations/{convId} {
      // Only participants can read the conversation
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Only a participant can create a conversation they belong to
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // Only participants can update metadata (lastMessage, lastMessageAt)
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants; // can't change participants

      allow delete: if false;

      // ── MESSAGES ──────────────────────────────────────────
      match /messages/{msgId} {
        // Only participants of the parent conversation can read messages
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        // Only participants can create messages, and only as themselves
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.senderId == request.auth.uid;

        // Only status updates allowed after creation (delivered/read)
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

        // Messages are never deleted
        allow delete: if false;
      }
    }
  }
}
